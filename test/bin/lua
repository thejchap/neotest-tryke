#!/bin/sh

# Shim that makes Neovim act as a Lua interpreter for busted.

# Handle Lua command-line arguments
while getopts 'ilEve:' opt; do
	case $opt in
		e) lua_expr=$OPTARG;;
		v) nvim --version; exit;;
		i | l | E) echo "Option '$opt' not supported by shim"; exit 1;;
	esac
done

NEOTEST_RTP="$HOME/.local/share/nvim/lazy/neotest"
NIO_RTP="$HOME/.local/share/nvim/lazy/nvim-nio"
INIT='lua package.path = "lua/?.lua;lua/?/init.lua;" .. package.path; if vim.fn.isdirectory("'"$NIO_RTP"'") == 1 then vim.opt.runtimepath:append("'"$NIO_RTP"'") end; if vim.fn.isdirectory("'"$NEOTEST_RTP"'") == 1 then vim.opt.runtimepath:append("'"$NEOTEST_RTP"'") end'

if [ -n "$lua_expr" ]; then
	nvim --headless --noplugin -u NONE --cmd "$INIT" -c "lua $lua_expr" -c 'quitall!'
else
	nvim --headless --noplugin -u NONE --cmd "$INIT" -l "$@"
fi

exit $?
